{
	"compilerOptions": {
		"target": "ES2020",
		"module": "preserve",
		"moduleResolution": "bundler",
		"types": ["node", "bun"],
		"strict": true,
		"declaration": true,
		"sourceMap": true,
		"noUnusedLocals": true,
		"esModuleInterop": true,
		"verbatimModuleSyntax": true
	},
	"include": ["src", "tests"]
}
